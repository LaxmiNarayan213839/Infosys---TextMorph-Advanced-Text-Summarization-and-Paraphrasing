# Copy this file to .env and fill in your values
# cp .env.example .env

# ---------------------------
# JWT Secret Key
# Used for session tokens
# Use any long random string
# Example: openssl rand -hex 32
# ---------------------------
JWT_SECRET=change-this-to-a-strong-random-secret

# ---------------------------
# Gmail App Password
# NOT your normal Gmail password
# How to get it:
# 1. Go to myaccount.google.com
# 2. Security → 2-Step Verification → ON
# 3. Search "App Passwords"
# 4. Create one for "Mail"
# 5. Paste the 16-char password below
# ---------------------------
EMAIL_PASSWORD=your-16-char-gmail-app-password

# ---------------------------
# Database Path (for Docker)
# Do not change this
# ---------------------------
DB_PATH=/app/data/users.db
